{
  "expo": {
    "name": "FieldForce Live",
    "slug": "fieldforce-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fieldforce-mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1b35"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fieldforce.live"
    },
    "android": {
      "package": "com.fieldforce.live",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0f1b35"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": false
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "FieldForce needs your location to track your field route and report it to your manager.",
          "locationWhenInUsePermission": "FieldForce needs your location to track your field route."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
