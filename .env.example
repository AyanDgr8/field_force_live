# Copy to .env and fill in. .env is gitignored.
#
# Local MySQL connection.
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your-password
MYSQL_PORT=3306
MYSQL_DATABASE=fieldforce

# Signs the admin session JWT. Any non-empty string works locally.
SESSION_SECRET=dev-secret-local-only

# Google Workspace SMTP (use an app password, not the account password).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your-email@example.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=Field Force Monitor <your-email@example.com>

# Optional. Both dev scripts fall back to their own defaults when unset.
# Do NOT export PORT globally — api-server and fieldforce-admin both read it
# and would collide on the same port.
# API_PORT=7070
# FRONTEND_PORT=7075
# BASE_PATH=/
# API_PROXY_TARGET=http://localhost:7070

# Map provider: "leaflet" (OpenStreetMap, no API key) or "google".
VITE_MAP_PROVIDER=leaflet

# Required only when VITE_MAP_PROVIDER=google.
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
