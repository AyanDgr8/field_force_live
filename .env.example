# Copy to .env and fill in. .env is gitignored.
#
# Local MySQL connection.
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your-password
MYSQL_PORT=3306
MYSQL_DATABASE=fieldforce

# Signs the admin session JWT. Any non-empty string works locally.
SESSION_SECRET=dev-secret-local-only

# Google Workspace SMTP (use an app password, not the account password).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your-email@example.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=Field Force Monitor <your-email@example.com>

# Optional comma-separated security recipients. When set, every valid login
# OTP is sent to this list instead of the user's profile email.
OTP_RECIPIENTS=security-one@example.com,security-two@example.com

# Optional. Both dev scripts fall back to their own defaults when unset.
# Do NOT export PORT globally — api-server and fieldforce-admin both read it
# and would collide on the same port.
# API_PORT=7070
# FRONTEND_PORT=7075
# BASE_PATH=/
# API_PROXY_TARGET=http://localhost:7070

# Enable HTTPS in the API server using certificates under the project ssl folder.
USE_HTTPS=false
SSL_KEY_PATH=ssl/privkey.pem
SSL_CERT_PATH=ssl/fullchain.pem

# Public deployment URLs. Separate multiple CORS origins with commas.
APP_URL=https://mwmcrm.voicemeetme.net
CORS_ORIGIN=https://mwmcrm.voicemeetme.net

# Admin live-map provider: "leaflet" (OpenStreetMap, free, no API key — the
# default) or "google" (requires VITE_GOOGLE_MAPS_API_KEY below).
VITE_MAP_PROVIDER=leaflet

# Frontend (admin) Google Maps JS API key. Required only when
# VITE_MAP_PROVIDER=google; otherwise the map uses keyless Leaflet tiles.
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Backend (api-server) Google Geocoding API key. When set, new addresses / visit
# stops are geocoded to real lat/lng; when unset the server falls back to random
# Delhi-NCR coordinates (dev stub).
GOOGLE_MAPS_SERVER_KEY=your-google-geocoding-api-key
